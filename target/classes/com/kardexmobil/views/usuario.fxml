<?xml version="1.0" encoding="UTF-8"?>

<?import com.gluonhq.charm.glisten.mvc.View?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.*?>

<View fx:id="usuarioView" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.kardexmobil.views.UsuarioPresenter">
   <center>
      <ScrollPane fitToWidth="true" style="-fx-background-color: #F8FAFC;">
         <content>
            <VBox spacing="20.0" style="-fx-padding: 15;">
               <children>
                  
                  <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20;">
                     <effect>
                        <DropShadow color="#0000000D" radius="15.0" />
                     </effect>
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #E11D2A;" text="● DATOS DEL USUARIO" />
                        
                        <VBox spacing="12.0">
                           <children>
                              <TextField fx:id="txtUsuario" prefHeight="45.0" promptText="Nombre de usuario" style="-fx-background-radius: 8;" />
                              <PasswordField fx:id="txtPassword" prefHeight="45.0" promptText="Contraseña" style="-fx-background-radius: 8;" />
                              <ComboBox fx:id="cbRol" maxWidth="Infinity" prefHeight="45.0" promptText="Seleccionar Rol" style="-fx-background-radius: 8;" />
                              <ComboBox fx:id="cbSucursal" maxWidth="Infinity" prefHeight="45.0" promptText="Seleccionar Sucursal" style="-fx-background-radius: 8;" />
                           </children>
                        </VBox>

                        <VBox spacing="10.0">
                           <children>
                              <Button maxWidth="Infinity" onAction="#guardar" prefHeight="50.0" style="-fx-background-color: #E11D2A; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="GUARDAR / ACTUALIZAR" />
                              <HBox spacing="10.0">
                                 <children>
                                    <Button maxWidth="Infinity" onAction="#limpiarCampos" prefHeight="45.0" style="-fx-background-color: #475569; -fx-text-fill: white; -fx-background-radius: 8;" text="LIMPIAR" HBox.hgrow="ALWAYS" />
                                    <Button maxWidth="Infinity" onAction="#eliminar" prefHeight="45.0" style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-background-radius: 8;" text="ELIMINAR" HBox.hgrow="ALWAYS" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </children>
                  </VBox>

                  <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #64748B;" text="USUARIOS REGISTRADOS" />
                        <TableView fx:id="tblUsuarios" prefHeight="350.0" style="-fx-background-radius: 10;">
                           <columns>
                              <TableColumn fx:id="colUser" prefWidth="120.0" text="Usuario" />
                              <TableColumn fx:id="colRol" prefWidth="100.0" text="Rol" />
                              <TableColumn fx:id="colSucursal" prefWidth="120.0" text="Sede" />
                           </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </children>
                  </VBox>

               </children>
            </VBox>
         </content>
      </ScrollPane>
   </center>
</View>