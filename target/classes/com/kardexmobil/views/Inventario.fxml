<?xml version="1.0" encoding="UTF-8"?>

<?import com.gluonhq.charm.glisten.mvc.View?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<View fx:id="inventarioView" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.kardexmobil.views.InventarioPresenter">
    <center>
        <VBox spacing="0.0" style="-fx-background-color: #F8FAFC;">
            <children>
                
                <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #E2E8F0; -fx-border-width: 0 0 1 0;">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #1E293B; -fx-font-size: 13px;" text="👤 RESPONSABLE DEL MOVIMIENTO" />
                        <HBox spacing="10.0">
                            <children>
                                <TextField fx:id="txtDniColaborador" prefHeight="55.0" promptText="DNI / RUC" style="-fx-font-size: 16px;" HBox.hgrow="ALWAYS" />
                                <Button onAction="#buscarColaborador" prefHeight="55.0" style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 0 20 0 20;" text="VERIFICAR" />
                            </children>
                        </HBox>
                        <Label fx:id="lblNombreColaborador" style="-fx-text-fill: #E11D2A; -fx-font-weight: bold; -fx-font-size: 14px;" text="Esperando identificación..." wrapText="true" />
                    </children>
                </VBox>

                <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
                    <tabs>
                        <Tab text="📦 EPPS Y UNIFORMES">
                            <content>
                                <VBox spacing="12.0" style="-fx-padding: 12;">
                                    <children>
                                        <TextField fx:id="txtBuscarI" prefHeight="45.0" promptText="🔍 Buscar EPP..." style="-fx-font-size: 14px;" />
                                        
                                        <HBox spacing="12.0">
                                            <children>
                                                <Button maxWidth="Infinity" onAction="#agregarInventario" prefHeight="38.0" prefWidth="140.0" style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px; -fx-background-radius: 10;" text="➕ ENTRADA" HBox.hgrow="ALWAYS" />
                                                <Button maxWidth="Infinity" onAction="#descontarInsumo" prefHeight="37.0" prefWidth="124.0" style="-fx-background-color: #E11D2A; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px; -fx-background-radius: 10;" text="➖ SALIDA" HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>

                                        <TableView fx:id="tblInventario" prefHeight="336.0" prefWidth="314.0" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="colInsumo" prefWidth="150.0" text="Nombre" />
                                                <TableColumn fx:id="colActual" prefWidth="100.0" text="Stock" />
                                            </columns>
                                            <columnResizePolicy>
                                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                            </columnResizePolicy>
                                        </TableView>
                                    </children>
                                </VBox>
                            </content>
                        </Tab>

                        <Tab text="🏭 HERRAMIENTAS">
                            <content>
                                <VBox spacing="12.0" style="-fx-padding: 12;">
                                    <children>
                                        <TextField fx:id="txtBuscarP" prefHeight="45.0" promptText="🔍 Buscar Insumo..." style="-fx-font-size: 14px;" />
                                        
                                        <HBox spacing="10.0">
                                            <children>
                                                <Button maxWidth="Infinity" onAction="#agregarStockProducto" prefHeight="39.0" prefWidth="140.0" style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 0;" text="➕ ENTRADA" HBox.hgrow="ALWAYS" />
              
                                                <Button maxWidth="Infinity" onAction="#descontarStockProducto" prefHeight="40.0" prefWidth="135.0" style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 0;" text="➖ SALIDA" HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>

                                        <TableView fx:id="tblProductosStock" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="colProdNombre" prefWidth="150.0" text="Insumo" />
                                                <TableColumn fx:id="colProdStock" prefWidth="100.0" text="Actual" />
                                            </columns>
                                            <columnResizePolicy>
                                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                            </columnResizePolicy>
                                        </TableView>
                                    </children>
                                </VBox>
                            </content>
                        </Tab>
                    </tabs>
                </TabPane>

                <HBox alignment="CENTER" spacing="12.0" style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #E2E8F0; -fx-border-width: 1 0 0 0;">
                    <children>
                        <Button maxWidth="Infinity" onAction="#generarReporteInventario" prefHeight="41.0" prefWidth="134.0" style="-fx-background-color: #E11D2A; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 10;" text="📄 EXPORTAR PDF" HBox.hgrow="ALWAYS" />
                        
                        <Button maxWidth="Infinity" onAction="#generarReporteCSV" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #059669; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 10;" text="📊 EXPORTAR EXCEL" HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</View>
