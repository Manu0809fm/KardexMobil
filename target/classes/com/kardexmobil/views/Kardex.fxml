<?xml version="1.0" encoding="UTF-8"?>

<?import com.gluonhq.charm.glisten.mvc.View?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<View fx:id="historialView" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.kardexmobil.views.HistorialInventarioPresenter">
   <center>
      <VBox spacing="0.0" style="-fx-background-color: #F8FAFC;">
         <children>
            
            <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #E2E8F0; -fx-border-width: 0 0 1 0;">
               <children>
                  <Label style="-fx-font-weight: bold; -fx-text-fill: #1E293B; -fx-font-size: 13px;" text="🔍 FILTRAR MOVIMIENTOS" />
                  
                  <TextField fx:id="txtBuscar" prefHeight="50.0" promptText="Buscar producto, tipo o responsable..." style="-fx-font-size: 14px;" />
                  
                  <HBox spacing="10.0">
                     <children>
                        <DatePicker fx:id="dpInicio" prefHeight="50.0" promptText="Desde" HBox.hgrow="ALWAYS" />
                        <DatePicker fx:id="dpFin" prefHeight="50.0" promptText="Hasta" HBox.hgrow="ALWAYS" />
                        <Button onAction="#cargarDatos" prefHeight="50.0" prefWidth="60.0" 
                                style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-font-weight: bold;" text="OK" />
                     </children>
                  </HBox>
               </children>
            </VBox>

            <VBox spacing="8.0" VBox.vgrow="ALWAYS" style="-fx-padding: 10 10 10 10;">
               <children>
                  <Label style="-fx-font-weight: bold; -fx-font-size: 11px; -fx-text-fill: #64748B;" text="Toca un registro para ver detalles en el sistema" />
                  
                  <TableView fx:id="tablaMovimientos" VBox.vgrow="ALWAYS">
                      <columns>
                          <TableColumn fx:id="colFecha" prefWidth="100.0" text="Fecha" />
                          <TableColumn fx:id="colID" prefWidth="120.0" text="Item" />
                          <TableColumn fx:id="colTipo" prefWidth="80.0" text="Tipo" />
                      </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
            </VBox>

            <HBox alignment="CENTER" spacing="12.0" style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #E2E8F0; -fx-border-width: 1 0 0 0;">
               <children>
                  <Button maxWidth="Infinity" onAction="#exportarPDF" prefHeight="60.0" 
                          style="-fx-background-color: #E11D2A; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 10;" 
                          text="📄 EXPORTAR PDF" HBox.hgrow="ALWAYS" />
                  
                  <Button maxWidth="Infinity" onAction="#exportarCSV" prefHeight="60.0" 
                          style="-fx-background-color: #059669; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 10;" 
                          text="📊 EXPORTAR EXCEL" HBox.hgrow="ALWAYS" />
               </children>
            </HBox>

         </children>
      </VBox>
   </center>
</View>